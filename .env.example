# ============================================================
# AlphaBot Environment Variables
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your real values below
#   3. NEVER commit your .env file to Git (it's in .gitignore)
# ============================================================

# ── Schwab / ThinkorSwim API ─────────────────────────────────
# Get these from: https://developer.schwab.com
# 1. Create a free account
# 2. Click "Add an App"
# 3. Copy App Key and Secret below

SCHWAB_APP_KEY=your_app_key_here
SCHWAB_APP_SECRET=your_app_secret_here
SCHWAB_CALLBACK_URL=https://127.0.0.1
SCHWAB_ACCOUNT_NUMBER=your_account_number_here

# ── Anthropic (Claude AI) ────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Optional: Notification Alerts ───────────────────────────
# Get a free bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
